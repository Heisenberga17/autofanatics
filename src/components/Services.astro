---
import { SERVICES, SECTION_IDS } from "../lib/constants";
import { buildWhatsAppUrl } from "../lib/utils";

const featured = SERVICES.find((s) => s.featured)!;
const nonFeatured = SERVICES.filter((s) => !s.featured);
const medium = nonFeatured.slice(0, 2);
const compact = nonFeatured.slice(2);

const iconPaths: Record<string, string> = {
  Shield: `<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>`,
  Sparkles: `<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/>`,
  Paintbrush: `<path d="m14.622 17.897-10.68-2.913"/><path d="M18.376 2.622a1 1 0 1 1 3.002 3.002L17.36 9.643a.5.5 0 0 0 0 .707l.944.944a2.41 2.41 0 0 1 0 3.408l-.944.944a.5.5 0 0 1-.707 0L8.354 7.348a.5.5 0 0 1 0-.707l.944-.944a2.41 2.41 0 0 1 3.408 0l.944.944a.5.5 0 0 0 .707 0z"/><path d="M9 8c-1.804 2.71-3.97 3.46-6.583 3.948a.507.507 0 0 0-.302.819l7.32 8.883a1 1 0 0 0 1.185.204C12.735 20.405 16 16.792 16 15"/>`,
  Sun: `<circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>`,
  Car: `<path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/>`,
};
---
<section id={SECTION_IDS.services} class="section-separator relative py-24 lg:py-32 bg-bg-primary">
  <!-- Subtle radial gradient background -->
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(212,43,43,0.03)_0%,transparent_70%)]"></div>

  <div class="relative mx-auto max-w-6xl px-4">
    <!-- Section Header -->
    <div class="mb-16 text-center" data-fade>
      <span class="mb-4 inline-block font-accent text-xs font-semibold uppercase tracking-[0.2em] text-accent">Servicios Premium</span>
      <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
        <span class="text-accent-gradient">Nuestros Servicios</span>
      </h2>
      <p class="mx-auto max-w-2xl text-base text-text-secondary lg:text-lg">
        Ofrecemos soluciones completas de detailing y protecci&oacute;n para tu veh&iacute;culo con productos y t&eacute;cnicas de clase mundial.
      </p>
    </div>

    <!-- Zone 1: Featured Service -->
    <div class="mb-12" data-fade>
      <div class="overflow-hidden rounded-2xl border border-border bg-bg-secondary">
        <div class="grid grid-cols-1 lg:grid-cols-2">
          <!-- Image -->
          <div class="relative aspect-[4/3] lg:aspect-auto">
            <img
              src={featured.image}
              alt={featured.title}
              class="absolute inset-0 h-full w-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-bg-secondary/80 via-transparent to-transparent lg:bg-gradient-to-r lg:from-transparent lg:via-transparent lg:to-bg-secondary/60"></div>
          </div>
          <!-- Content -->
          <div class="flex flex-col justify-center p-8 lg:p-12">
            <div class="mb-4 flex items-center gap-3">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-accent/10 px-3 py-1 text-xs font-semibold text-accent">
                <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
                Destacado
              </span>
            </div>
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-accent/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-accent">
                <Fragment set:html={iconPaths[featured.icon]} />
              </svg>
            </div>
            <h3 class="mb-3 font-heading text-2xl font-bold text-text-primary lg:text-3xl">{featured.title}</h3>
            <p class="mb-6 leading-relaxed text-text-secondary">{featured.description}</p>
            <a
              href={buildWhatsAppUrl(featured.whatsappMessage)}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary w-fit"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
                <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22z"/>
              </svg>
              Consultar por WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Zone 2: Medium Services -->
    <div class="mb-12 grid grid-cols-1 gap-6 sm:grid-cols-2">
      {medium.map((service, i) => (
        <div data-fade data-fade-delay={i * 100}>
          <div class="group relative overflow-hidden rounded-2xl border border-border">
            <!-- Image -->
            <div class="relative aspect-[3/4] sm:aspect-[4/5]">
              <img
                src={service.image}
                alt={service.title}
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <!-- Overlay gradient -->
              <div class="absolute inset-0 bg-gradient-to-t from-bg-primary via-bg-primary/60 to-transparent"></div>
            </div>
            <!-- Content at bottom -->
            <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-accent">
                  <Fragment set:html={iconPaths[service.icon]} />
                </svg>
              </div>
              <h3 class="mb-2 font-heading text-xl font-bold text-text-primary">{service.title}</h3>
              <p class="mb-4 text-sm leading-relaxed text-text-secondary">{service.description}</p>
              <a
                href={buildWhatsAppUrl(service.whatsappMessage)}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-outline text-sm"
              >
                Consultar
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Zone 3: Compact Services -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {compact.map((service, i) => (
        <div data-fade data-fade-delay={(i + 2) * 100}>
          <div class="group flex overflow-hidden rounded-2xl border border-border bg-bg-secondary transition-colors duration-300 hover:border-border-light">
            <!-- Thumbnail -->
            <div class="relative w-32 shrink-0 sm:w-40">
              <img
                src={service.image}
                alt={service.title}
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <!-- Content -->
            <div class="flex flex-1 flex-col justify-center p-5 sm:p-6">
              <div class="mb-2 flex h-8 w-8 items-center justify-center rounded-lg bg-accent/10">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-accent">
                  <Fragment set:html={iconPaths[service.icon]} />
                </svg>
              </div>
              <h3 class="mb-1 font-heading text-lg font-bold text-text-primary">{service.title}</h3>
              <p class="mb-3 text-sm leading-relaxed text-text-secondary">{service.description}</p>
              <a
                href={buildWhatsAppUrl(service.whatsappMessage)}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 text-sm font-medium text-accent transition-colors hover:text-accent-light"
              >
                Consultar
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

---
import { SECTION_IDS, INSTAGRAM_URL, INSTAGRAM_HANDLE, GALLERY_IMAGES } from '../lib/constants';
import BeforeAfterSlider from './BeforeAfterSlider.astro';
---

<section id={SECTION_IDS.gallery} class="section-separator relative py-24 lg:py-32 bg-bg-secondary">
  <div class="relative mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section Header -->
    <div class="mb-16 text-center" data-fade>
      <span class="mb-4 inline-block font-accent text-xs font-semibold uppercase tracking-[0.2em] text-accent">Portafolio</span>
      <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
        <span class="text-accent-gradient">Galer&iacute;a de Resultados</span>
      </h2>
      <p class="mx-auto max-w-2xl text-base text-text-secondary lg:text-lg">
        Cada veh&iacute;culo es una obra de arte. Descubre la transformaci&oacute;n que logramos con nuestros servicios premium.
      </p>
    </div>

    <!-- Full-width Cinematic Image -->
    <div class="mb-12 overflow-hidden rounded-2xl border border-border" data-fade>
      <div class="relative h-64 md:h-96">
        <img
          src={GALLERY_IMAGES[0].src}
          alt={GALLERY_IMAGES[0].alt}
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-6 md:p-8">
          <span class="mb-1 block font-accent text-xs font-semibold uppercase tracking-[0.2em] text-accent">Portfolio</span>
          <span class="block font-heading text-xl font-bold text-text-primary md:text-2xl">Nuestro Trabajo</span>
        </div>
      </div>
    </div>

    <!-- Masonry Grid -->
    <div class="mb-12 grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6">
      <!-- Left Column -->
      <div class="space-y-4 md:space-y-6">
        <div class="overflow-hidden rounded-2xl border border-border" data-fade data-fade-delay="100">
          <div class="relative aspect-[4/3]">
            <img
              src={GALLERY_IMAGES[1].src}
              alt={GALLERY_IMAGES[1].alt}
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 hover:scale-105"
              loading="lazy"
            />
          </div>
        </div>
        <div class="overflow-hidden rounded-2xl border border-border" data-fade data-fade-delay="300">
          <div class="relative aspect-[3/4]">
            <img
              src={GALLERY_IMAGES[3].src}
              alt={GALLERY_IMAGES[3].alt}
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 hover:scale-105"
              loading="lazy"
            />
          </div>
        </div>
      </div>

      <!-- Right Column (staggered) -->
      <div class="space-y-4 pt-0 sm:pt-12 md:space-y-6">
        <div class="overflow-hidden rounded-2xl border border-border" data-fade data-fade-delay="200">
          <div class="relative aspect-[3/4]">
            <img
              src={GALLERY_IMAGES[2].src}
              alt={GALLERY_IMAGES[2].alt}
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 hover:scale-105"
              loading="lazy"
            />
          </div>
        </div>
        <div class="overflow-hidden rounded-2xl border border-border" data-fade data-fade-delay="400">
          <div class="relative aspect-[4/3]">
            <img
              src={GALLERY_IMAGES[4].src}
              alt={GALLERY_IMAGES[4].alt}
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 hover:scale-105"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Before / After Slider -->
    <div class="mb-12" data-fade data-fade-delay="200">
      <BeforeAfterSlider beforeSrc={GALLERY_IMAGES[5].src} afterSrc={GALLERY_IMAGES[4].src} />
      <p class="mt-3 text-center text-sm text-text-muted">
        Desliza para comparar &mdash; Correcci&oacute;n de Pintura
      </p>
    </div>

    <!-- Instagram CTA -->
    <div class="text-center" data-fade data-fade-delay="600">
      <a
        href={INSTAGRAM_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline inline-flex items-center gap-2"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5"/>
          <circle cx="12" cy="12" r="5"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
        {INSTAGRAM_HANDLE}
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

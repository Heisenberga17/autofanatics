---
import { SECTION_IDS, WHY_US_FEATURES } from '../lib/constants';

const iconSvgPaths: Record<string, string> = {
  Award: `<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>`,
  BadgeCheck: `<path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76z"/><path d="m9 12 2 2 4-4"/>`,
  Gem: `<path d="M6 3h12l4 6-10 13L2 9z"/><path d="M11 3 8 9l4 13 4-13-3-6"/><path d="M2 9h20"/>`,
  MapPin: `<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>`,
};
---

<section id={SECTION_IDS.whyUs} class="relative bg-bg-primary py-24 lg:py-32 section-separator">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Left Column: Photo -->
      <div class="relative" data-fade>
        <div class="relative overflow-hidden rounded-2xl">
          <img
            src="/images/detailer-at-work.jpg"
            alt="Detailer profesional trabajando"
            class="h-full w-full object-cover aspect-[4/5]"
            loading="lazy"
          />
          <!-- Red overlay -->
          <div class="absolute inset-0 bg-accent/10"></div>
          <!-- Text overlay at bottom -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6 md:p-8">
            <span class="font-accent text-xs font-semibold uppercase tracking-[0.2em] text-accent">Auto Fanatics</span>
            <p class="mt-1 font-heading text-lg font-bold text-text-primary md:text-xl">Premium Detailing Studio</p>
          </div>
        </div>
        <!-- Corner accents -->
        <div class="hidden sm:block absolute -top-3 -left-3 h-12 w-12 border-t-2 border-l-2 border-accent rounded-tl-lg"></div>
        <div class="hidden sm:block absolute -bottom-3 -right-3 h-12 w-12 border-b-2 border-r-2 border-accent rounded-br-lg"></div>
      </div>

      <!-- Right Column: Features -->
      <div>
        <!-- Header -->
        <div class="mb-10" data-fade>
          <span class="mb-4 inline-block font-accent text-xs font-semibold uppercase tracking-[0.2em] text-accent">Diferenciadores</span>
          <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
            <span class="text-accent-gradient">&iquest;Por Qu&eacute; Elegirnos?</span>
          </h2>
          <p class="max-w-lg text-base text-text-secondary lg:text-lg">
            Combinamos certificaci&oacute;n internacional, productos premium y pasi&oacute;n por los autos para ofrecer resultados excepcionales.
          </p>
        </div>

        <!-- Features List -->
        <div class="space-y-6">
          {WHY_US_FEATURES.map((feature, i) => (
            <div class="flex items-start gap-4" data-fade data-fade-delay={i * 120}>
              <!-- Icon Circle -->
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-accent/30 bg-accent/5">
                <svg viewBox="0 0 24 24" class="h-5 w-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={iconSvgPaths[feature.icon]} />
                </svg>
              </div>
              <!-- Text -->
              <div>
                <h3 class="mb-1 font-heading text-base font-bold text-text-primary">{feature.title}</h3>
                <p class="text-sm leading-relaxed text-text-secondary">{feature.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

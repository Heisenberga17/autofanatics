---
interface Props {
  direction?: "left" | "right";
  fillColor?: string;
  className?: string;
}
const { direction = "left", fillColor = "#0a0a0a", className = "" } = Astro.props;
const points = direction === "left" ? "0,0 100,40 100,0" : "0,40 100,0 0,0";
---
<div class={`relative w-full overflow-hidden leading-[0] ${className}`}>
  <svg viewBox="0 0 100 40" preserveAspectRatio="none" class="block h-[40px] w-full md:h-[60px]">
    <polygon points={points} fill={fillColor} />
  </svg>
</div>

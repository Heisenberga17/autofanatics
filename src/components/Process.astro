---
import { PROCESS_STEPS, SECTION_IDS } from '../lib/constants';

const iconSvgPaths: Record<string, string> = {
  Search: `<path d="M11 2a9 9 0 1 0 0 18 9 9 0 0 0 0-18z"/><path d="m21 21-4.3-4.3"/>`,
  Droplets: `<path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/>`,
  Wrench: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>`,
  ShieldCheck: `<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>`,
  CheckCircle: `<circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/>`,
};
---

<section id={SECTION_IDS.process} class="section-separator relative py-24 lg:py-32 bg-bg-secondary carbon-fiber-bg">
  <!-- Faint atmosphere image -->
  <div class="pointer-events-none absolute inset-0">
    <img
      src="/images/hero-car.jpg"
      alt=""
      class="h-full w-full object-cover opacity-[0.04]"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-bg-secondary/95"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section Header -->
    <div class="mb-16 text-center" data-fade>
      <span class="mb-4 inline-block font-accent text-xs font-semibold uppercase tracking-[0.2em] text-accent">Proceso</span>
      <h2 class="mb-4 font-heading text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
        <span class="text-accent-gradient">Nuestro Proceso</span>
      </h2>
      <p class="mx-auto max-w-2xl text-base text-text-secondary lg:text-lg">
        Cinco pasos meticulosos para garantizar resultados excepcionales en cada veh&iacute;culo.
      </p>
    </div>

    <!-- Desktop Horizontal Timeline -->
    <div class="hidden lg:block">
      <!-- Connecting line -->
      <div class="relative">
        <div class="absolute left-[10%] right-[10%] top-10 h-px bg-gradient-to-r from-transparent via-accent to-transparent"></div>

        <div class="grid grid-cols-5 gap-6">
          {PROCESS_STEPS.map((step, i) => (
            <div class="flex flex-col items-center text-center" data-fade data-fade-delay={i * 150}>
              <!-- Circle with icon -->
              <div class="relative mb-6">
                <div class="flex h-20 w-20 items-center justify-center rounded-full border-2 border-accent bg-bg-secondary">
                  <svg viewBox="0 0 24 24" class="h-8 w-8 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <Fragment set:html={iconSvgPaths[step.icon]} />
                  </svg>
                </div>
                <!-- Number badge -->
                <span class="absolute -top-2 -right-2 flex h-7 w-7 items-center justify-center rounded-full bg-accent text-xs font-bold text-white">
                  {step.number}
                </span>
              </div>
              <!-- Title -->
              <h3 class="mb-2 font-heading text-lg font-bold text-text-primary">{step.title}</h3>
              <!-- Description -->
              <p class="text-sm leading-relaxed text-text-secondary">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Mobile Vertical Timeline -->
    <div class="lg:hidden">
      <div class="ml-6 border-l-2 border-accent/30 pl-10">
        {PROCESS_STEPS.map((step, i) => (
          <div class="relative pb-12 last:pb-0" data-fade data-fade-delay={i * 150}>
            <!-- Circle on the line -->
            <div class="absolute -left-[calc(2.5rem+1.5px)] flex h-12 w-12 items-center justify-center rounded-full border-2 border-accent bg-bg-secondary">
              <svg viewBox="0 0 24 24" class="h-5 w-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={iconSvgPaths[step.icon]} />
              </svg>
            </div>
            <!-- Title -->
            <h3 class="mb-1 font-heading text-lg font-bold text-text-primary">{step.title}</h3>
            <!-- Description -->
            <p class="text-sm leading-relaxed text-text-secondary">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

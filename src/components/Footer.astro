---
import {
  NAV_LINKS,
  BUSINESS_NAME,
  WHATSAPP_DISPLAY,
  WHATSAPP_NUMBER,
  BUSINESS_ADDRESS,
  BUSINESS_HOURS,
  INSTAGRAM_HANDLE,
  INSTAGRAM_URL,
} from '../lib/constants';

const currentYear = new Date().getFullYear();

const CONTACT_DETAILS = [
  { label: WHATSAPP_DISPLAY, href: `https://wa.me/${WHATSAPP_NUMBER}`, icon: "phone" },
  { label: BUSINESS_ADDRESS, href: null, icon: "map-pin" },
  { label: BUSINESS_HOURS, href: null, icon: "clock" },
  { label: INSTAGRAM_HANDLE, href: INSTAGRAM_URL, icon: "instagram" },
];
---

<footer class="relative bg-bg-primary border-t border-border">
  <!-- Checkered pattern -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.02]" style="background-image: repeating-conic-gradient(#fff 0% 25%, transparent 0% 50%); background-size: 24px 24px;"></div>

  <!-- Red gradient top line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent to-transparent"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 py-16 lg:px-8 lg:py-20">
    <!-- 3-column grid -->
    <div class="grid grid-cols-1 gap-12 md:grid-cols-3 md:gap-8">
      <!-- Column 1: Logo & About -->
      <div data-fade>
        <img src="/images/logo.svg" alt="Auto Fanatics" class="h-10 w-auto" />
        <p class="mt-4 text-sm leading-relaxed text-text-secondary">
          Estudio profesional de detailing automotriz en Panam&aacute;. Protecci&oacute;n cer&aacute;mica, correcci&oacute;n de pintura y servicios premium para tu veh&iacute;culo.
        </p>
        <!-- IGL Badge -->
        <div class="mt-6 inline-flex items-center gap-2 rounded-full border border-border bg-bg-secondary px-4 py-2">
          <svg viewBox="0 0 24 24" class="h-4 w-4 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
          </svg>
          <span class="text-xs font-medium text-text-secondary">Distribuidor Autorizado IGL Coatings</span>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div data-fade data-fade-delay="100">
        <h3 class="mb-6 font-heading text-sm font-bold uppercase tracking-wider text-text-primary">Enlaces R&aacute;pidos</h3>
        <nav>
          <ul class="space-y-3">
            {NAV_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="inline-flex items-center gap-2 text-sm text-text-secondary transition-colors duration-200 hover:text-accent"
                >
                  <svg viewBox="0 0 24 24" class="h-3 w-3 text-accent/50" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/>
                    <path d="m12 5 7 7-7 7"/>
                  </svg>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Column 3: Contact -->
      <div data-fade data-fade-delay="200">
        <h3 class="mb-6 font-heading text-sm font-bold uppercase tracking-wider text-text-primary">Contacto</h3>
        <ul class="space-y-4">
          {CONTACT_DETAILS.map((detail) => {
            const inner = (
              <div class="flex items-center gap-3">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent/10">
                  {detail.icon === "phone" && (
                    <svg viewBox="0 0 24 24" class="h-4 w-4 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                  )}
                  {detail.icon === "map-pin" && (
                    <svg viewBox="0 0 24 24" class="h-4 w-4 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
                      <circle cx="12" cy="10" r="3"/>
                    </svg>
                  )}
                  {detail.icon === "clock" && (
                    <svg viewBox="0 0 24 24" class="h-4 w-4 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"/>
                      <polyline points="12 6 12 12 16 14"/>
                    </svg>
                  )}
                  {detail.icon === "instagram" && (
                    <svg viewBox="0 0 24 24" class="h-4 w-4 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="2" y="2" width="20" height="20" rx="5"/>
                      <circle cx="12" cy="12" r="5"/>
                      <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
                    </svg>
                  )}
                </div>
                <span class="text-sm text-text-secondary">{detail.label}</span>
              </div>
            );

            return (
              <li>
                {detail.href ? (
                  <a href={detail.href} target="_blank" rel="noopener noreferrer" class="block transition-opacity duration-200 hover:opacity-80">
                    {inner}
                  </a>
                ) : (
                  inner
                )}
              </li>
            );
          })}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 border-t border-border pt-8 text-center" data-fade data-fade-delay="300">
      <p class="text-xs text-text-muted">
        &copy; {currentYear} {BUSINESS_NAME}. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>

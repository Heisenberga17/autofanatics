<section class="bg-bg-secondary py-6">
  <div class="mx-auto max-w-7xl px-6 lg:px-8" data-fade>
    <!-- Desktop: horizontal with red separators -->
    <div class="hidden md:flex items-center justify-center gap-4 lg:gap-8">
      <div class="flex items-center gap-2 text-xs sm:text-sm text-text-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-accent"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
        <span>Distribuidor Certificado IGL Coatings</span>
      </div>
      <div class="h-4 w-px bg-accent/40"></div>
      <div class="flex items-center gap-2 text-xs sm:text-sm text-text-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-accent"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
        <span>Detailing Profesional Certificado</span>
      </div>
      <div class="h-4 w-px bg-accent/40"></div>
      <div class="flex items-center gap-2 text-xs sm:text-sm text-text-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-accent"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
        <span>Costa del Este, Panam&aacute;</span>
      </div>
    </div>

    <!-- Mobile: stacked with dot separators -->
    <div class="flex flex-col items-center gap-3 md:hidden">
      <div class="flex items-center gap-2 text-xs sm:text-sm text-text-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-accent"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
        <span>Distribuidor Certificado IGL Coatings</span>
      </div>
      <span class="text-accent/40 text-xs">&bull;</span>
      <div class="flex items-center gap-2 text-xs sm:text-sm text-text-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-accent"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
        <span>Detailing Profesional Certificado</span>
      </div>
      <span class="text-accent/40 text-xs">&bull;</span>
      <div class="flex items-center gap-2 text-xs sm:text-sm text-text-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-accent"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
        <span>Costa del Este, Panam&aacute;</span>
      </div>
    </div>
  </div>
</section>

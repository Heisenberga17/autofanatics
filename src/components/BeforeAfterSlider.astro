---
interface Props {
  beforeSrc: string;
  afterSrc: string;
  beforeLabel?: string;
  afterLabel?: string;
  className?: string;
}
const { beforeSrc, afterSrc, beforeLabel = "ANTES", afterLabel = "DESPUÉS", className = "" } = Astro.props;
---

<div class={`ba-slider relative select-none overflow-hidden rounded-2xl border border-neutral-800 aspect-[4/3] w-full cursor-col-resize ${className}`} style="touch-action: none" data-before-src={beforeSrc} data-after-src={afterSrc}>
  <!-- After image (bottom layer) -->
  <img src={afterSrc} alt={afterLabel} class="absolute inset-0 h-full w-full object-cover" draggable="false" />

  <!-- Before image (top layer, clipped) -->
  <div class="ba-before absolute inset-0 h-full w-full" style="clip-path: inset(0 50% 0 0)">
    <img src={beforeSrc} alt={beforeLabel} class="absolute inset-0 h-full w-full object-cover" draggable="false" />
  </div>

  <!-- Before label -->
  <div class="ba-label-before pointer-events-none absolute left-4 top-4 rounded-full bg-black/60 px-3 py-1.5 backdrop-blur-sm transition-opacity duration-200">
    <span class="font-accent text-xs font-semibold uppercase tracking-wider text-text-primary">{beforeLabel}</span>
  </div>

  <!-- After label -->
  <div class="ba-label-after pointer-events-none absolute right-4 top-4 rounded-full bg-black/60 px-3 py-1.5 backdrop-blur-sm transition-opacity duration-200">
    <span class="font-accent text-xs font-semibold uppercase tracking-wider text-text-primary">{afterLabel}</span>
  </div>

  <!-- Handle -->
  <div class="ba-handle pointer-events-none absolute top-0 bottom-0 z-10" style="left: 50%; transform: translateX(-50%)">
    <!-- Vertical line -->
    <div class="absolute inset-y-0 left-1/2 w-0.5 -translate-x-1/2" style="background: linear-gradient(180deg, transparent 0%, #D42B2B 10%, #D42B2B 90%, transparent 100%); box-shadow: 0 0 12px rgba(212, 43, 43, 0.4)"></div>
    <!-- Circle grip -->
    <div class="absolute left-1/2 top-1/2 flex h-10 w-10 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border-2 border-accent bg-bg-primary/90 backdrop-blur-sm" style="box-shadow: 0 0 20px rgba(212, 43, 43, 0.5)">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" class="text-accent">
        <path d="M5.5 6L2.5 9L5.5 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M12.5 6L15.5 9L12.5 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>
</div>

<script>
function initSliders() {
  document.querySelectorAll<HTMLElement>('.ba-slider').forEach(slider => {
    const before = slider.querySelector<HTMLElement>('.ba-before');
    const handle = slider.querySelector<HTMLElement>('.ba-handle');
    const labelBefore = slider.querySelector<HTMLElement>('.ba-label-before');
    const labelAfter = slider.querySelector<HTMLElement>('.ba-label-after');
    if (!before || !handle) return;

    let position = 50;
    let isDragging = false;
    let hasAnimated = false;

    function updatePosition(pct: number) {
      position = Math.max(0, Math.min(100, pct));
      before.style.clipPath = `inset(0 ${100 - position}% 0 0)`;
      handle.style.left = `${position}%`;
      if (labelBefore) labelBefore.style.opacity = position > 15 ? '1' : '0';
      if (labelAfter) labelAfter.style.opacity = position < 85 ? '1' : '0';
    }

    slider.addEventListener('pointerdown', (e: PointerEvent) => {
      e.preventDefault();
      isDragging = true;
      (e.target as HTMLElement).setPointerCapture(e.pointerId);
      const rect = slider.getBoundingClientRect();
      updatePosition(((e.clientX - rect.left) / rect.width) * 100);
    });

    slider.addEventListener('pointermove', (e: PointerEvent) => {
      if (!isDragging) return;
      e.preventDefault();
      const rect = slider.getBoundingClientRect();
      updatePosition(((e.clientX - rect.left) / rect.width) * 100);
    });

    slider.addEventListener('pointerup', () => { isDragging = false; });
    slider.addEventListener('pointercancel', () => { isDragging = false; });

    // Auto-slide animation on first viewport entry
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !hasAnimated) {
          hasAnimated = true;
          observer.disconnect();
          const startPos = 70;
          const endPos = 50;
          const duration = 1200;
          const startTime = performance.now();
          updatePosition(startPos);
          function animate(currentTime: number) {
            const elapsed = currentTime - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            updatePosition(startPos + (endPos - startPos) * eased);
            if (progress < 1) requestAnimationFrame(animate);
          }
          requestAnimationFrame(animate);
        }
      });
    }, { threshold: 0.3 });
    observer.observe(slider);
  });
}
initSliders();
document.addEventListener('astro:page-load', initSliders);
</script>
